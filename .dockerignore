# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include embedded data files needed by go:embed directives
# (e.g. internal/gitleaks/default_rules.toml referenced by scanner.go)
!**/*.toml

# Re-include prompt templates for the claude-subagent image
# (internal/subagent/common/prompt_templates.go: //go:embed templates/*.tmpl).
# Without this, `**` excludes the .tmpl files and the claude-subagent build
# fails with "pattern templates/*.tmpl: no matching files found".
!**/*.tmpl

# Re-include the dashboard SPA bundle for the dashboard image build
# (cmd/dashboard/embed/embed.go: //go:embed all:dist requires dist/ contents).
# This was added in Phase 04.1 Plan 14 UAT closeout when the dashboard image
# was split out of the shared controller Dockerfile (Dockerfile.dashboard).
!cmd/dashboard/embed/dist/**

# Re-include tide-git-http-server config/entrypoint (Phase 8 in-cluster git-http server).
# These are shell/nginx config files not matched by the Go/toml/tmpl patterns above.
!images/tide-git-http-server/nginx.conf
!images/tide-git-http-server/entrypoint.sh

# Re-include dashboard/web source for the spa-builder node stage in Dockerfile.dashboard
# (Phase 22 FIX-01: multi-stage build regenerates dist/ from source, never trusts committed dist/).
# node_modules/ is intentionally excluded — npm ci runs inside the container and populates it there.
!dashboard/web/src/**
!dashboard/web/index.html
!dashboard/web/package.json
!dashboard/web/package-lock.json
!dashboard/web/vite.config.ts
!dashboard/web/tsconfig.json
!dashboard/web/tsconfig.app.json
!dashboard/web/tsconfig.node.json
!dashboard/web/.nvmrc
